# Synology 배포 .env (이 파일을 .env 로 복사해서 채우세요)
# =====================================================
# 모드 (A) managed Supabase / (B) self-host 중 택1. 자세한 건 README.md.

# ── 공통: 웹 서버 ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000                  # 컨테이너 내부 uvicorn 포트 (고정, 건드릴 필요 없음)
ADMIN_KEY=                 # openssl rand -hex 32  (관리자 API X-Admin-Key)
DEPLOY_ENV=synology        # Discord 알림 메시지에 붙는 출처 라벨

# ── 호스트(NAS) 공개 포트 — 같은 NAS 에 다른 프로젝트가 있어 충돌하면 여기서 변경 ──
WEB_PORT=8645              # 모드 A 진입점 (NAS:8645 → web)
PROXY_PORT=8646           # 모드 B 진입점 (NAS:8646 → Caddy)

# ── Discord 알림 (docs/05). 없으면 알림 자동 off (no-op) ────────────────────────
DISCORD_WEBHOOK_URL=

# ════════════════════════════════════════════════════════════════════════════════
# 모드 (A) managed Supabase  — web 컨테이너만 띄움
#   docker compose up -d --build
# ────────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY

# ════════════════════════════════════════════════════════════════════════════════
# 모드 (B) self-host  — db + rest + proxy + web
#   docker compose --profile selfhost up -d --build
#   → 위 SUPABASE_URL/KEY 를 아래 값으로 교체:
#
#   SUPABASE_URL=http://proxy          # Caddy 가 /rest/v1/* → PostgREST 로 라우팅
#   SUPABASE_KEY=<gen_keys.py 의 ANON_KEY>
#
# 아래 시크릿은 self-host 모드에서만 필요:
#   openssl rand -base64 24  /  openssl rand -base64 48
# ────────────────────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=
AUTHENTICATOR_PASSWORD=    # PGRST_DB_URI 와 db 역할 비번 동기화 (compose 가 둘 다 사용)
JWT_SECRET=               # anon/service 키 서명 + PostgREST 검증 공용. gen_keys.py 입력값.
# SUPABASE_SERVICE_KEY=<gen_keys.py 의 SERVICE_KEY>   # 크롤러 적재용 (웹 서빙엔 불필요)
