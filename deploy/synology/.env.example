# Synology 배포 .env (이 파일을 .env 로 복사해서 채우세요)
# =====================================================
# 모드 (A) managed Supabase / (B) self-host 중 택1. 자세한 건 README.md.
# 자동 세팅:  bash setup_env.sh   (모드 B 시크릿 일괄 생성)
#
# ⚠️ 값 줄에는 인라인 주석(끝의 # ...)을 달지 말 것 — env_file 로 컨테이너에 그대로
#    전달돼 값이 깨질 수 있음. 주석은 항상 값 줄 "위"에 둔다.

# ── 공통: 웹 서버 ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
# 컨테이너 내부 uvicorn 포트 (고정, 건드릴 필요 없음)
PORT=8000
# 관리자 API X-Admin-Key.  openssl rand -hex 32
ADMIN_KEY=
# Discord 알림 메시지에 붙는 출처 라벨
DEPLOY_ENV=synology

# ── 호스트(NAS) 공개 포트 — 다른 프로젝트와 충돌하면 여기서 변경 ─────────────────
# 모드 A 진입점 (NAS:8645 → web)
WEB_PORT=8645
# 모드 B 진입점 (NAS:8646 → Caddy)
PROXY_PORT=8646

# ── Discord 알림 (docs/05). 없으면 알림 자동 off (no-op) ────────────────────────
DISCORD_WEBHOOK_URL=

# ════════════════════════════════════════════════════════════════════════════════
# 모드 (A) managed Supabase  — web 컨테이너만 띄움
#   docker compose up -d --build
# 클라우드 Supabase 대시보드 → Settings → API 의 값 사용:
# ────────────────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=YOUR_SUPABASE_ANON_KEY

# ════════════════════════════════════════════════════════════════════════════════
# 모드 (B) self-host  — db + rest + proxy + web
#   docker compose --profile selfhost up -d --build
# 위 SUPABASE_URL/KEY 를 아래 값으로 교체 (setup_env.sh 가 자동 처리):
#   SUPABASE_URL=http://proxy
#   SUPABASE_KEY=<gen_keys.py 의 ANON_KEY>
#
# 아래 시크릿은 self-host 모드에서만 필요:
#   openssl rand -base64 24   (POSTGRES_PASSWORD / AUTHENTICATOR_PASSWORD)
#   openssl rand -base64 48   (JWT_SECRET)
# ────────────────────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=
# PGRST_DB_URI 와 db 역할 비번 동기화 (compose 가 둘 다 사용)
AUTHENTICATOR_PASSWORD=
# anon/service 키 서명 + PostgREST 검증 공용. gen_keys.py 입력값.
JWT_SECRET=
# 크롤러 적재용 (웹 서빙엔 불필요). gen_keys.py 의 SERVICE_KEY.
# SUPABASE_SERVICE_KEY=
