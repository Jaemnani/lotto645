# ── Supabase PostgreSQL 연결 ────────────────────────────────────────────────────
# Supabase 프로젝트 → Settings → Database → Connection string (URI) 에서 복사
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# ── 관리자 API 키 ────────────────────────────────────────────────────────────────
# POST /api/admin/fetch-and-calc 호출 시 X-Admin-Key 헤더에 사용
ADMIN_KEY=your_secret_admin_key_here

# ── 서버 설정 ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# DEV=true  # 핫리로드 활성화 (개발 환경에서만)

# ── Discord 알림 (docs/05) — 없으면 알림 자동 off (no-op), 기존 동작 불변 ─────────
# 채널 → 설정 → 연동 → 웹후크 → 새 웹후크 → URL 복사
# 서버: 스케줄러 잡(토요일 통계/재학습) 알림 / 크롤러 머신: cron·crawl 시작·종료 요약
DISCORD_WEBHOOK_URL=
# 알림 메시지에 붙는 출처 라벨 (oracle / synology / imac 등 구분용)
DEPLOY_ENV=

# ── Synology self-host 모드 (deploy/synology, docs/02·06) ────────────────────────
# managed Supabase 대신 NAS 안 Postgres+PostgREST 를 쓸 때만. 자세한 건 deploy/synology/README.md
# SUPABASE_URL=http://proxy
# SUPABASE_KEY=<gen_keys.py ANON_KEY>
# POSTGRES_PASSWORD=
# AUTHENTICATOR_PASSWORD=
# JWT_SECRET=

# ── 맥미니 크롤링용 (기존) ──────────────────────────────────────────────────────
# NAVER_ID=your_naver_id
# NAVER_PW=your_naver_password
# GEMINI_API_KEY=your_gemini_api_key
